# Dodo AI Service env (copy to .env for local dev)

APP_ENV=local
APP_DEBUG=true
LOG_LEVEL=INFO

# Anthropic — leave blank to run in STUB MODE (no real LLM calls)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL_DEFAULT=claude-3-5-haiku-latest
ANTHROPIC_MODEL_PREMIUM=claude-3-5-sonnet-latest
ANTHROPIC_MODEL_VISION=claude-3-5-sonnet-latest

# Pandora Core (RS256 JWT)
PANDORA_CORE_BASE_URL=http://localhost:8001
PANDORA_CORE_ISSUER=https://id.js-store.com.tw
PANDORA_CORE_PUBLIC_KEY_TTL=3600
PANDORA_CORE_ALLOWED_PRODUCTS=doudou

# Laravel internal callback (HMAC shared secret) — outbound ai-service -> Laravel
LARAVEL_INTERNAL_BASE_URL=http://laravel:8000
LARAVEL_INTERNAL_SHARED_SECRET=change-me-in-prod

# Inbound internal auth — Laravel dodo backend -> ai-service. Empty => the
# X-Internal-Secret path is disabled and only Bearer JWT is accepted.
INTERNAL_SHARED_SECRET=

# Cost guard
DEFAULT_DAILY_TOKEN_BUDGET=200000

# Safety
MIN_KCAL_PER_DAY=1200
MIN_KCAL_PER_MEAL=800
VISION_CONFIDENCE_THRESHOLD=0.85
