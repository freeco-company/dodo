# =============================================================================
# Dodo Backend (Laravel) — production .env template
# Copy to /var/www/dodo/backend/.env on the Linode box and fill in real values.
# Stub-OK keys can be left blank for first deploy; STUB-OK behaviour is noted.
# REQUIRED keys must have a real value before production traffic.
# =============================================================================

# ---- App ----
APP_NAME="Dodo (朵朵)"
APP_ENV=production
APP_KEY=                                  # REQUIRED — `php artisan key:generate --show` then paste
APP_DEBUG=false
APP_URL=https://dodo.js-store.com.tw

APP_LOCALE=zh_TW
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=zh_TW

LOG_CHANNEL=stack
LOG_STACK=daily
LOG_LEVEL=info
LOG_DEPRECATIONS_CHANNEL=null

BCRYPT_ROUNDS=12

# ---- DB (shared MariaDB on Linode, dedicated schema) ----
DB_CONNECTION=mysql                       # REQUIRED
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=dodo                          # REQUIRED — `CREATE DATABASE dodo CHARACTER SET utf8mb4`
DB_USERNAME=dodo                          # REQUIRED — dedicated user, GRANT ALL ON dodo.* TO 'dodo'@'localhost'
DB_PASSWORD=                              # REQUIRED — strong password, min 24 chars

# ---- Session / Cache / Queue ----
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=.dodo.js-store.com.tw      # so frontend subdomain shares cookie if ever needed

CACHE_STORE=redis                         # use shared Redis (dodo uses DB index 2)
QUEUE_CONNECTION=database                 # database queue is fine until throughput rises;
                                          # consider redis later (DB index 3)

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=null                       # set if Redis requirepass is configured
REDIS_DB=2                                # 0=mothership, 1=platform, 2=dodo-backend, 3=dodo-queue

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# ---- Mail (use Postmark / SES / Resend in prod; stub via log driver is OK) ----
MAIL_MAILER=log                           # STUB-OK — change to ses/postmark when needed
MAIL_FROM_ADDRESS="noreply@dodo.js-store.com.tw"
MAIL_FROM_NAME="${APP_NAME}"

# ---- Admin token (Filament + admin endpoints purge / analytics flush) ----
DODO_ADMIN_TOKEN=                         # REQUIRED — `openssl rand -hex 32`

# ---- Pandora Core Identity (ADR-007 Phase 4) ----
# REQUIRED if cutover is on. id.js-store.com.tw is already deployed (HANDOFF §B).
PANDORA_CORE_BASE_URL=https://id.js-store.com.tw
PANDORA_CORE_JWT_ISSUER=https://id.js-store.com.tw
PANDORA_CORE_JWT_AUDIENCE=dodo
PANDORA_CORE_WEBHOOK_SECRET=              # REQUIRED — must match platform's IDENTITY_CONSUMER_DODO_SECRET
PANDORA_CORE_WEBHOOK_WINDOW_SECONDS=300

# ---- Dodo AI service (FastAPI on same box, loopback) ----
DODO_AI_SERVICE_BASE_URL=http://127.0.0.1:8002
DODO_AI_SERVICE_SHARED_SECRET=            # REQUIRED — must match ai-service INTERNAL_SHARED_SECRET (`openssl rand -hex 32`)
DODO_AI_SERVICE_TIMEOUT=30

# ---- py-service (conversion funnel) ----
PANDORA_CONVERSION_BASE_URL=http://127.0.0.1:8003
PANDORA_CONVERSION_SHARED_SECRET=         # REQUIRED — must match py-service INTERNAL_SHARED_SECRET
PANDORA_CONVERSION_APP_ID=doudou
PANDORA_CONVERSION_TIMEOUT=5

# ---- IAP (Apple / Google) ----
IAP_STUB_MODE=true                        # STUB-OK initially; flip to false when keys are real
IAP_APPLE_SHARED_SECRET=                  # REQUIRED for prod IAP — App Store Connect > In-App Purchase > App-Specific Shared Secret
IAP_APPLE_BUNDLE_ID=com.dodo.app
IAP_GOOGLE_SERVICE_ACCOUNT_JSON=          # REQUIRED for prod IAP — path to JSON file: /var/www/dodo/secrets/iap-google.json
IAP_GOOGLE_PACKAGE_NAME=com.dodo.app

# ---- ECPay (Taiwan recurring billing) ----
ECPAY_MERCHANT_ID=                        # REQUIRED for prod payments
ECPAY_HASH_KEY=                           # REQUIRED for prod payments
ECPAY_HASH_IV=                            # REQUIRED for prod payments
ECPAY_AIO_ENDPOINT=https://payment.ecpay.com.tw/Cashier/AioCheckOut/V5   # production endpoint (no -stage)
ECPAY_RETURN_URL=https://dodo.js-store.com.tw/api/billing/ecpay/return
ECPAY_PERIOD_RETURN_URL=https://dodo.js-store.com.tw/api/billing/ecpay/period-return
ECPAY_CLIENT_BACK_URL=https://app.dodo.js-store.com.tw/billing/done

# ---- PostHog analytics ----
POSTHOG_API_KEY=                          # STUB-OK — empty disables flush, events still write to DB
POSTHOG_HOST=https://app.posthog.com
POSTHOG_BATCH_SIZE=200

# ---- FCM push ----
FCM_SERVICE_ACCOUNT_JSON=                 # STUB-OK initially — path to /var/www/dodo/secrets/fcm.json
FCM_PROJECT_ID=
FCM_DRY_RUN=true                          # STUB-OK — flip to false once notifications are verified

# ---- Sentry / monitoring (TODO) ----
# SENTRY_LARAVEL_DSN=                     # TODO — add when monitoring story lands
# SENTRY_TRACES_SAMPLE_RATE=0.1
