# =============================================================================
# Dodo AI Service (FastAPI) — production .env template
# Copy to /var/www/dodo/ai-service/.env on the Linode box.
# =============================================================================

APP_ENV=production
APP_DEBUG=false
LOG_LEVEL=INFO

# ---- Anthropic (Claude) ----
# STUB-OK: leave blank to run in stub mode (no real LLM calls; fixed sample
# responses). For real food vision / chat, fill in.
ANTHROPIC_API_KEY=                        # STUB-OK
ANTHROPIC_MODEL_DEFAULT=claude-3-5-haiku-latest
ANTHROPIC_MODEL_PREMIUM=claude-3-5-sonnet-latest
ANTHROPIC_MODEL_VISION=claude-3-5-sonnet-latest

# ---- Pandora Core (verifies inbound JWTs from frontend / dodo-backend) ----
PANDORA_CORE_BASE_URL=https://id.js-store.com.tw
PANDORA_CORE_ISSUER=https://id.js-store.com.tw
PANDORA_CORE_PUBLIC_KEY_TTL=3600          # how long to cache /api/v1/auth/public-key
PANDORA_CORE_ALLOWED_PRODUCTS=doudou      # comma list — only doudou JWTs accepted

# ---- Outbound: ai-service -> dodo-backend (callback writes for vision/chat) ----
LARAVEL_INTERNAL_BASE_URL=http://127.0.0.1                           # backend served by nginx on local box (port 80 internal) — adjust if backend listens elsewhere
LARAVEL_INTERNAL_SHARED_SECRET=                                       # REQUIRED — same as backend's PANDORA_CORE / internal callback secret pair (TODO: confirm key name; see CLAUDE.md notes)

# ---- Inbound: dodo-backend -> ai-service (X-Internal-Secret) ----
INTERNAL_SHARED_SECRET=                   # REQUIRED — must match backend DODO_AI_SERVICE_SHARED_SECRET (`openssl rand -hex 32`)

# ---- Cost guard ----
DEFAULT_DAILY_TOKEN_BUDGET=200000

# ---- Safety thresholds ----
MIN_KCAL_PER_DAY=1200
MIN_KCAL_PER_MEAL=800
VISION_CONFIDENCE_THRESHOLD=0.85

# ---- Sentry / monitoring (TODO) ----
# SENTRY_DSN=
# SENTRY_TRACES_SAMPLE_RATE=0.1
