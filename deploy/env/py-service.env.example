# =============================================================================
# py-service (Pandora group conversion / lifecycle) — production .env template
# Code lives in a separate repo; this template is provided here because all
# six services share the same Linode host and operators want one source of
# truth. Copy to /var/www/py-service/.env.
# =============================================================================

APP_ENV=production
APP_DEBUG=false
LOG_LEVEL=INFO

# ---- Database ----
# py-service prefers PostgreSQL (asyncpg). On Linode 4GB we either:
#   (a) install PostgreSQL alongside MariaDB (recommended; small footprint), or
#   (b) point at a managed Postgres (Linode Managed DB / Neon free tier).
DATABASE_URL=postgresql+asyncpg://pyservice:CHANGE_ME@127.0.0.1:5432/pandora_conversion   # REQUIRED

# ---- Pandora Core (verifies inbound JWTs) ----
PANDORA_CORE_BASE_URL=https://id.js-store.com.tw
PANDORA_CORE_ISSUER=https://id.js-store.com.tw
PANDORA_CORE_ALLOWED_PRODUCTS=doudou,pandora_js_store,fairy_calendar    # extend as new products onboard

# ---- Internal auth (mothership / dodo-backend -> py-service) ----
INTERNAL_SHARED_SECRET=                   # REQUIRED — same value used by mothership + dodo-backend in PANDORA_CONVERSION_SHARED_SECRET

# ---- Outbound: py-service -> mothership (read customer orders) ----
MOTHERSHIP_BASE_URL=https://js-store.com.tw                              # REQUIRED — mothership prod URL (TODO confirm)
MOTHERSHIP_INTERNAL_SECRET=                                              # REQUIRED — mothership-side internal endpoint secret
MOTHERSHIP_TIMEOUT=5

# ---- Sentry / monitoring (TODO) ----
# SENTRY_DSN=
