APP_NAME="潘朵拉飲食"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# 集團統一用 MariaDB（與母艦 pandora.js-store 一致）
# 本機開發若 DB 未建好可暫用 sqlite：DB_CONNECTION=sqlite
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=dodo
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Admin endpoints (purge / analytics flush / SEO mgmt)
DODO_ADMIN_TOKEN=

# === Pandora Core Identity (ADR-007 Phase 4) ===
# Platform 端 identity service base URL，朵朵會抓 /api/v1/auth/public-key
PANDORA_CORE_BASE_URL=
PANDORA_CORE_JWT_ISSUER=pandora-core-identity
PANDORA_CORE_JWT_AUDIENCE=dodo
# 與 platform 端 IDENTITY_CONSUMER_DODO_SECRET 一致
PANDORA_CORE_WEBHOOK_SECRET=
PANDORA_CORE_WEBHOOK_WINDOW_SECONDS=300

# === Apple Sign-In (POST /api/auth/apple) ===
# client_id matches the JWT `aud` claim Apple stamps on identity_token.
# For native iOS sign-in this is the app bundle id; for web it's the Service ID.
APPLE_CLIENT_ID=com.jerosse.pandora.meal
# Below three reserved for server-side authorization_code → refresh_token
# exchange (not yet wired). Pull from Apple Developer Console.
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=
# Set true ONLY in tests / local dev. Production must be false.
APPLE_AUTH_STUB_MODE=false

# === LINE Login (POST /api/auth/line) ===
# Channel ID from LINE Developers console; matches JWT `aud`.
LINE_CHANNEL_ID=
LINE_CHANNEL_SECRET=
# Set true ONLY in tests / local dev. Production must be false.
LINE_AUTH_STUB_MODE=false

# === Phase E — IAP (Apple / Google) ===
# Set to true ONLY in dev / E2E. Production must be false (or unset).
IAP_STUB_MODE=false
# App-Specific Shared Secret from App Store Connect. Without this, real Apple
# receipt verification throws IapNotConfiguredException → 503.
IAP_APPLE_SHARED_SECRET=
IAP_APPLE_BUNDLE_ID=com.jerosse.pandora.meal
# Google service-account JSON (single-line escaped) + package name.
IAP_GOOGLE_SERVICE_ACCOUNT_JSON=
IAP_GOOGLE_PACKAGE_NAME=com.jerosse.pandora.meal

# === Pre-launch app version handshake (kill switch via /api/bootstrap) ===
# Bump MIN_* on a forced-upgrade release; bump RECOMMENDED_* on a soft nag.
# Defaults to 1 so unset env never accidentally locks anyone out.
MIN_IOS_BUILD=1
RECOMMENDED_IOS_BUILD=1
MIN_ANDROID_BUILD=1
RECOMMENDED_ANDROID_BUILD=1

# === Phase 5c — Knowledge Base OCR (kb:ocr-import command) ===
# Required ONLY when running `php artisan kb:ocr-import` to batch-process
# storage/seed/nutrition_kb/raw/ images via Claude vision API.
# Estimated cost: ~$0.015/image × 160 images ≈ $2.4 USD per full run.
# Get key from https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# === Sentry crash reporting (pre-launch hardening) ===
# Set in prod only; empty disables Sentry (SDK becomes noop). Local / CI must
# leave this empty so dev errors don't pollute the prod project.
# DSN format: https://<key>@<org>.ingest.sentry.io/<project>
SENTRY_LARAVEL_DSN=
# Optional: tag events with current git SHA so you can blame a deploy.
# deploy script:  export SENTRY_RELEASE=$(git rev-parse --short HEAD)
SENTRY_RELEASE=
# Performance traces — keep at 0 unless actively debugging slow endpoints
# (each transaction counts toward Sentry quota).
SENTRY_TRACES_SAMPLE_RATE=0.0
SENTRY_PROFILES_SAMPLE_RATE=0.0

# === HIBP password breach check (Pwned Passwords k-anonymity) ===
# Default ON in production; flip to false in CI / E2E / local if network flaky.
HIBP_CHECK_ENABLED=true
